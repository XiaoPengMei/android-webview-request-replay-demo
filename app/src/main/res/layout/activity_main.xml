<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/scope_title"
        android:textAppearance="@style/TextAppearance.AppCompat.Title" />

    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/status_starting" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/loadButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/load_local_page" />

        <Button
            android:id="@+id/replayButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:enabled="false"
            android:text="@string/replay_captured_get" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/captured_request_label"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="#FFF3F4F6"
        android:fillViewport="true"
        android:padding="8dp">

        <TextView
            android:id="@+id/capturedRequestTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_request_captured"
            android:textIsSelectable="true"
            android:textSize="12sp"
            android:typeface="monospace" />
    </ScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/replay_response_label"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="#FFF3F4F6"
        android:fillViewport="true"
        android:padding="8dp">

        <TextView
            android:id="@+id/replayResponseTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_replay_yet"
            android:textIsSelectable="true"
            android:textSize="12sp"
            android:typeface="monospace" />
    </ScrollView>

    <WebView
        android:id="@+id/demoWebView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1" />

</LinearLayout>
