<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/scope_title"
        android:textAppearance="@style/TextAppearance.AppCompat.Title" />

    <TextView
        android:id="@+id/statusTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/status_starting" />

    <TextView
        android:id="@+id/modeLabelTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/mode_label"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/modeRadioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/controlledModeRadioButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/mode_controlled" />

        <RadioButton
            android:id="@+id/genericModeRadioButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checked="true"
            android:text="@string/mode_generic" />
    </RadioGroup>

    <LinearLayout
        android:id="@+id/controlledActionsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/loadButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/load_local_page" />

        <Button
            android:id="@+id/replayButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:enabled="false"
            android:text="@string/replay_captured_get" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/genericUrlContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/genericUrlEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/generic_url_hint"
            android:importantForAutofill="no"
            android:inputType="textUri"
            android:maxLines="1" />

        <Button
            android:id="@+id/loadGenericUrlButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/load_generic_url" />
    </LinearLayout>

    <TextView
        android:id="@+id/capturedRequestLabelTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/captured_request_label"
        android:textStyle="bold" />

    <ScrollView
        android:id="@+id/capturedRequestContainer"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="#FFF3F4F6"
        android:fillViewport="true"
        android:padding="8dp">

        <TextView
            android:id="@+id/capturedRequestTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_request_captured"
            android:textIsSelectable="true"
            android:textSize="12sp"
            android:typeface="monospace" />
    </ScrollView>

    <TextView
        android:id="@+id/replayResponseLabelTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/replay_response_label"
        android:textStyle="bold" />

    <ScrollView
        android:id="@+id/replayResponseContainer"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="#FFF3F4F6"
        android:fillViewport="true"
        android:padding="8dp">

        <TextView
            android:id="@+id/replayResponseTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_replay_yet"
            android:textIsSelectable="true"
            android:textSize="12sp"
            android:typeface="monospace" />
    </ScrollView>

    <WebView
        android:id="@+id/demoWebView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1" />

</LinearLayout>
